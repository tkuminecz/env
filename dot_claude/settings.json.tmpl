{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(*)",
      "Search(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(ls *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(mise *)",
      "Bash(git *)",
      "Bash(gh pr *)",
      "Bash(curl *)",
      "Bash(find *)"
    ],
    "deny": [],
    "ask": [
      "Bash(git push * --force*)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "enabledMcpjsonServers": [
    "superset-test",
    "superset-staging",
    "superset-prod",
    "langfuse-test",
    "langfuse-staging",
    "langfuse-prod",
    "sentry",
    "linear"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{ .chezmoi.homeDir }}/.claude/hooks/pre_tool_call.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '{{ .chezmoi.homeDir }}/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "coderabbit@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": false
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    {{- /* cutd runs on tim-dev; point at it over the network from every
    other machine, and at localhost on tim-dev itself. */}}
    {{- if eq .chezmoi.hostname "tim-dev" }}
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:8420"
    {{- else }}
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://tim-dev:8420"
    {{- end }}
  }
}
